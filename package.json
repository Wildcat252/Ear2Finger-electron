{
  "name": "ear2finger",
  "version": "1.0.2",
  "private": true,
  "author": "Ear2Finger",
  "description": "Ear2Finger desktop: Electron UI + PyInstaller-bundled FastAPI backend + embedded Qdrant (qdrant-client local). Build: npm run electron:build:backend && npm run electron:pack.",
  "main": "electron/main.cjs",
  "scripts": {
    "electron:vendor": "node scripts/download-qdrant.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build:frontend": "npm install --prefix frontend && npm run build --prefix frontend",
    "electron:build:backend": "bash scripts/pyinstaller-build-backend.sh",
    "electron:pack": "npm run electron:build:backend && npm run electron:build:frontend && electron-builder"
  },
  "build": {
    "appId": "com.ear2finger.app",
    "productName": "Ear2Finger",
    "icon": "docs/assets/icon-bg.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/build/pyinstaller-dist/run_electron_backend",
        "to": "backend-bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "frontend/dist",
        "to": "frontend-dist"
      },
      {
        "from": "docs/assets/icon-bg.png",
        "to": "app-icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education",
      "maintainer": "Ear2Finger",
      "executableArgs": [
        "--no-sandbox",
        "--disable-setuid-sandbox"
      ]
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
