# Database
DATABASE_URL=sqlite:///./ear2finger.db

# Optional: Electron desktop app stores downloads/audio under userData if set
# EAR2FINGER_DOWNLOAD_DIR=
# EAR2FINGER_AUDIO_DIR=

# Auth
SECRET_KEY=your-secret-key-change-in-production

# Qdrant (vector store for AI coach)
# Option A — embedded local storage (no separate Qdrant server). Path must be writable.
# When set, QDRANT_URL / QDRANT_API_KEY are ignored.
# QDRANT_LOCAL_PATH=/path/to/qdrant-local-dir
#
# Option B — HTTP API (Docker or standalone qdrant binary on port 6333).
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Must match Gemini output_dimensionality / Qdrant vector size (768 recommended).
QDRANT_VECTOR_SIZE=768
# One-shot: if existing collections use a different size and have points, set to 1 to drop vectors and recreate.
# QDRANT_RECREATE_ON_VECTOR_MISMATCH=1
#
# Rebuild Qdrant collections: from backend/, `python scripts/rebuild_qdrant_collections.py` (loads .env).
# For npm run electron:dev without QDRANT_LOCAL_PATH in .env: add --electron-dev-path to that command.
# Gemini embedding model (legacy models/embedding-001 is not on v1beta).
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Gemini chat model (AI coach). Users still add API keys in Settings.
# GEMINI_MODEL=gemini-3-flash-preview
